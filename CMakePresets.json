{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "qt-mingw-desktop",
      "displayName": "Qt MinGW Desktop",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-qt-ascii",
      "cacheVariables": {
        "BUILD_TESTING": "ON",
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_PREFIX_PATH": "C:/Qt/6.10.3/mingw_64",
        "CMAKE_CXX_COMPILER": "C:/Qt/Tools/mingw1310_64/bin/g++.exe",
        "CMAKE_MAKE_PROGRAM": "C:/Qt/Tools/Ninja/ninja.exe",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "qt-mingw-desktop",
      "displayName": "Build Qt MinGW Desktop",
      "configurePreset": "qt-mingw-desktop",
      "jobs": 4
    }
  ],
  "testPresets": [
    {
      "name": "qt-mingw-desktop",
      "displayName": "Test Qt MinGW Desktop",
      "configurePreset": "qt-mingw-desktop",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
